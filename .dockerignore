# Docker ignore file — keep the build context lean and fast

# Git / version control
.git
.gitignore

# Python caches
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
*.egg
*.dist-info
*.whl

# Logs
*.log
logs/

# Documentation / notebooks (not needed at runtime)
*.md
*.ipynb

# Environment files (secrets live in Railway environment variables)
.env
.env.local
*.env*

# OS / editor metadata
.DS_Store
.vscode
.idea
node_modules
*~

# Virtual environments
.venv
venv/
env/

# Large model / data directories — mounted as volumes at runtime
voices/
models/

# Test / development folders
tests/
docs/
examples/

# Docker build artefacts
docker_build/
