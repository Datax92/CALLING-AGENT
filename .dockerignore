# Docker ignore file to reduce image size
.git
.gitignore
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
*.egg
*.dist-info
*.whl
*.log
*.md
# Exclude generic text files, but keep requirement files for Docker builds
*.txt
!requirements-*.txt
*.ipynb
.env
.env.local
*.DS_Store
.vscode
.idea
node_modules
tests
docs
examples
*~
# Exclude large model files (they will be mounted via volumes)
voices/
models/